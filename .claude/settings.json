{
  "cleanupPeriodDays": 30,
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(./**)",
      "Write(./src/**)",
      "Write(./app/**)",
      "Write(./components/**)",
      "Write(./lib/**)",
      "Write(./hooks/**)",
      "Write(./stores/**)",
      "Write(./types/**)",
      "Write(./public/**)",
      "Write(./supabase/**)",
      "Write(./styles/**)",
      "Write(./package.json)",
      "Write(./package-lock.json)",
      "Write(./pnpm-lock.yaml)",
      "Write(./yarn.lock)",
      "Write(./tailwind.config.*)",
      "Write(./next.config.*)",
      "Write(./tsconfig.json)",
      "Write(./CLAUDE.md)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(npx supabase:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git reset:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(vercel:*)",
      "Bash(supabase db reset:*)",
      "Bash(supabase db push:*)",
      "Bash(supabase migration repair:*)",
      "Bash(npm audit fix:*)",
      "Bash(npm update:*)",
      "Bash(pnpm update:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./**/*secret*)",
      "Read(./**/*credential*)",
      "Bash(rm -rf:*)",
      "Bash(del:*)",
      "Bash(format:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)"
    ]
  },
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}